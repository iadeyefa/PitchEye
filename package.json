{
  "dependencies": {
    "react-router-dom": "^7.13.0",
    "expo": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "name": "PitchEye",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend,mobile\" --prefix-colors \"yellow,cyan,magenta\" \"npm run backend\" \"npm run frontend\" \"npm run mobile\"",
    "backend": "cd backend && python manage.py runserver 0.0.0.0:8000",
    "frontend": "cd frontend && npm start",
    "mobile": "cd mobile && npx expo start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
