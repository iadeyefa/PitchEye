{
  "expo": {
    "name": "PitchEye",
    "slug": "pitcheye-qr-scanner",
    "version": "1.0.0",
    "orientation": "default",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to scan QR codes and record live streams",
        "NSMicrophoneUsageDescription": "This app needs microphone access to record live streams"
      }
    },
    "android": {
      "package": "com.pitcheye.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH"
      ]
    },
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "ea409398-59c6-4ad9-adef-304f90cbcbc2"
      }
    }
  }
}
