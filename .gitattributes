# Normalize line endings to LF in the repo for all text files
* text=auto eol=lf

# Explicitly declare common text files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.env text eol=lf

# Keep Windows batch files CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sqlite3 binary
